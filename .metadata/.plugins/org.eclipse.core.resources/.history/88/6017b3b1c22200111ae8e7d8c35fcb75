<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- bean definitions here -->

	<!--This is my Bean configuration -->
	<bean class="com.logic.Student" name="student1">
		<property name="StudentID">
			<value>112233</value>
		</property>

		<property name="studentName">
			<value>Aman</value>
		</property>

		<property name="studentAddress">
			<value>Delhi</value>
		</property>

	</bean>

	<bean class="com.logic.Student" name="student2">
		<property name="StudentID" value="2021" />

		<property name="studentName" value="Ajay" />

		<property name="studentAddress" value="Gurugram" />

	</bean>
	
	<bean class="com.logic.Student" name="student3" p:StudentID = "1122" p:studentName = "Swastik" p:studentAddress ="Gurugram">
		
	</bean>
</beans>